{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CPM_SOURCE_CACHE": "${sourceDir}/.cache/cpm",
        "MYTH_BUILD_SAMPLES": "ON",
        "MYTH_ENABLE_IMGUI_STANDARD": "ON",
        "MYTH_ENABLE_TRACY": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug (all features + samples)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release (all features + samples)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ]
}
